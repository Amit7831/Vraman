# ─────────────────────────────────────────────────────────────
#  Vraman Backend — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/Vraman

# ── Auth ──────────────────────────────────────────────────────────────────────
# Run: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_64_CHAR_RANDOM_HEX_BEFORE_DEPLOY

# ── Frontend URL (CORS) ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── ImageKit (image uploads) ──────────────────────────────────────────────────
# Sign up free at https://imagekit.io
# Dashboard → Developer Options → API Keys
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/YOUR_IMAGEKIT_ID

# ── Razorpay TEST MODE ────────────────────────────────────────────────────────
# Dashboard → Settings → API Keys → Test Mode
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_KEY_SECRET
